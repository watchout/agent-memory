{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/watchout/agent-memory/schemas/recovery-pack-v1.schema.json",
  "title": "Wasurezu Recovery Pack v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "project",
    "generated_at",
    "token_budget",
    "confidence",
    "confidence_reasons",
    "missing_context",
    "items"
  ],
  "properties": {
    "pack_id": { "type": "string", "minLength": 1 },
    "project": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "token_budget": { "type": "integer", "minimum": 1 },
    "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
    "confidence_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "missing_context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/$defs/recovery_pack_item" }
    },
    "schema_ref": {
      "const": "wasurezu-recovery-pack/v1"
    },
    "policy_version": { "type": "string", "minLength": 1 },
    "redaction_summary": {
      "$ref": "#/$defs/redaction_summary"
    },
    "retention_policy_ref": {
      "$ref": "#/$defs/nullable_ref"
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "missing_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "review_prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "expected_response_schema_ref"],
      "properties": {
        "review_id": { "type": "string", "minLength": 1 },
        "expected_response_schema_ref": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "recovery_pack_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "kind",
        "trust_level",
        "source_ref",
        "summary",
        "actionability",
        "sensitivity"
      ],
      "properties": {
        "item_id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "current_task",
            "decision",
            "knowledge",
            "recent_message",
            "raw_conversation",
            "file_hint",
            "risk"
          ]
        },
        "trust_level": {
          "type": "string",
          "enum": ["system", "project", "agent_memory", "external", "unknown"]
        },
        "source_ref": { "type": "string", "minLength": 1 },
        "source_time": { "type": "string", "format": "date-time" },
        "summary": { "type": "string", "minLength": 1 },
        "actionability": {
          "type": "string",
          "enum": ["must_read", "use_if_relevant", "background"]
        },
        "sensitivity": {
          "type": "string",
          "enum": ["public", "internal", "secret_redacted", "pii_redacted"]
        },
        "memory_safety_class": {
          "type": "string",
          "enum": [
            "raw_event_source",
            "candidate_memory",
            "approved_memory",
            "trusted_instruction",
            "untrusted_context"
          ]
        },
        "redaction_state": {
          "type": "string",
          "enum": [
            "redacted-before-emit",
            "already-redacted",
            "none-required",
            "unknown"
          ]
        },
        "promotion_evidence": {
          "$ref": "#/$defs/promotion_evidence"
        }
      }
    },
    "redaction_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "status",
        "private_reasoning_excluded",
        "redacted_counts",
        "omitted_counts",
        "notes"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "redacted-before-emit",
            "already-redacted",
            "none-required",
            "unknown"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "full",
            "partial",
            "degraded",
            "not_applicable"
          ]
        },
        "private_reasoning_excluded": {
          "const": true
        },
        "redacted_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "omitted_counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "promotion_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["promotion_ref"],
      "properties": {
        "promotion_ref": { "type": "string", "minLength": 1 },
        "promoted_at": { "type": "string", "format": "date-time" },
        "promoted_by": { "type": "string", "minLength": 1 },
        "policy_version": { "type": "string", "minLength": 1 }
      }
    },
    "nullable_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  }
}
