{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iyasaka.arc/schemas/governed-action-surface-profile.schema.json",
  "title": "Governed Action Surface Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_version",
    "product",
    "owner_repo",
    "surfaces"
  ],
  "properties": {
    "profile_version": {
      "type": "string",
      "pattern": "^0\\.1\\.0$"
    },
    "product": {
      "type": "string",
      "minLength": 1
    },
    "owner_repo": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actionSurface"
      }
    }
  },
  "$defs": {
    "surfaceType": {
      "type": "string",
      "enum": [
        "mcp_tool",
        "api_endpoint",
        "ui_action",
        "cli_command",
        "job",
        "webhook",
        "agent_action"
      ]
    },
    "capabilityClass": {
      "type": "string",
      "enum": [
        "read",
        "reveal",
        "write",
        "delete",
        "action",
        "external_send",
        "admin",
        "execute_code"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "interopMode": {
      "type": "string",
      "enum": [
        "none",
        "contract_ref",
        "event",
        "projection",
        "command_request",
        "artifact_ref",
        "manual_handoff"
      ]
    },
    "dependencyClass": {
      "type": "string",
      "enum": [
        "direct_db_write",
        "direct_db_read",
        "shared_internal_state",
        "internal_service_import",
        "shared_credentials",
        "remote_api_contract",
        "event_contract",
        "read_only_projection",
        "signed_command_request",
        "artifact_reference",
        "manual_operator_flow"
      ]
    },
    "rollbackKind": {
      "type": "string",
      "enum": [
        "none",
        "compensating_action",
        "restore_snapshot",
        "manual_reconcile",
        "not_reversible"
      ]
    },
    "actionSurface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface_id",
        "surface_type",
        "display_name",
        "description",
        "capability_classes",
        "risk_level",
        "boundary",
        "resource_scope",
        "identity_requirements",
        "context_requirements",
        "memory_requirements",
        "approval_policy",
        "audit_policy",
        "rollback_policy",
        "execution_policy"
      ],
      "properties": {
        "surface_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_.:-]*$"
        },
        "surface_type": {
          "$ref": "#/$defs/surfaceType"
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "capability_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/capabilityClass"
          },
          "uniqueItems": true
        },
        "risk_level": {
          "$ref": "#/$defs/riskLevel"
        },
        "boundary": {
          "$ref": "#/$defs/boundary"
        },
        "resource_scope": {
          "$ref": "#/$defs/resourceScope"
        },
        "identity_requirements": {
          "$ref": "#/$defs/identityRequirements"
        },
        "context_requirements": {
          "$ref": "#/$defs/contextRequirements"
        },
        "memory_requirements": {
          "$ref": "#/$defs/memoryRequirements"
        },
        "approval_policy": {
          "$ref": "#/$defs/approvalPolicy"
        },
        "audit_policy": {
          "$ref": "#/$defs/auditPolicy"
        },
        "rollback_policy": {
          "$ref": "#/$defs/rollbackPolicy"
        },
        "execution_policy": {
          "$ref": "#/$defs/executionPolicy"
        },
        "interop_contracts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interopContract"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standalone_required",
        "state_owner",
        "execution_owner",
        "policy_owner",
        "audit_owner",
        "interop_modes",
        "allowed_dependencies",
        "forbidden_dependencies",
        "direct_db_access_to_other_products",
        "receiving_product_revalidates"
      ],
      "properties": {
        "standalone_required": {
          "type": "boolean",
          "const": true
        },
        "state_owner": {
          "type": "string",
          "minLength": 1
        },
        "execution_owner": {
          "type": "string",
          "minLength": 1
        },
        "policy_owner": {
          "type": "string",
          "minLength": 1
        },
        "audit_owner": {
          "type": "string",
          "minLength": 1
        },
        "interop_modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/interopMode"
          },
          "uniqueItems": true
        },
        "allowed_dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependencyClass"
          },
          "uniqueItems": true
        },
        "forbidden_dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dependencyClass"
          },
          "uniqueItems": true
        },
        "direct_db_access_to_other_products": {
          "type": "boolean",
          "const": false
        },
        "receiving_product_revalidates": {
          "type": "boolean"
        }
      }
    },
    "resourceScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_scoped",
        "resource_patterns",
        "data_categories"
      ],
      "properties": {
        "tenant_scoped": {
          "type": "boolean"
        },
        "resource_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "data_categories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "identityRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actor_required",
        "agent_id_required",
        "human_user_required",
        "service_account_allowed"
      ],
      "properties": {
        "actor_required": {
          "type": "boolean"
        },
        "agent_id_required": {
          "type": "boolean"
        },
        "human_user_required": {
          "type": "boolean"
        },
        "service_account_allowed": {
          "type": "boolean"
        },
        "allowed_roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "contextRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "context_pack_required",
        "required_labels",
        "denied_labels",
        "prompt_injection_check_required"
      ],
      "properties": {
        "context_pack_required": {
          "type": "boolean"
        },
        "required_labels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "denied_labels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "prompt_injection_check_required": {
          "type": "boolean"
        }
      }
    },
    "memoryRequirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recovery_pack_required",
        "approval_note_required",
        "human_intent_ref_required"
      ],
      "properties": {
        "recovery_pack_required": {
          "type": "boolean"
        },
        "approval_note_required": {
          "type": "boolean"
        },
        "human_intent_ref_required": {
          "type": "boolean"
        }
      }
    },
    "approvalPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval_required",
        "approver_role",
        "approval_ttl_seconds",
        "reuse_allowed"
      ],
      "properties": {
        "approval_required": {
          "type": "boolean"
        },
        "approver_role": {
          "type": [
            "string",
            "null"
          ]
        },
        "approval_ttl_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "reuse_allowed": {
          "type": "boolean"
        }
      }
    },
    "auditPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audit_required",
        "input_summary_required",
        "output_summary_required",
        "mutation_summary_required",
        "egress_summary_required",
        "redaction_required"
      ],
      "properties": {
        "audit_required": {
          "type": "boolean",
          "const": true
        },
        "input_summary_required": {
          "type": "boolean"
        },
        "output_summary_required": {
          "type": "boolean"
        },
        "mutation_summary_required": {
          "type": "boolean"
        },
        "egress_summary_required": {
          "type": "boolean"
        },
        "redaction_required": {
          "type": "boolean"
        }
      }
    },
    "rollbackPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rollback_required",
        "rollback_kind",
        "replay_supported"
      ],
      "properties": {
        "rollback_required": {
          "type": "boolean"
        },
        "rollback_kind": {
          "$ref": "#/$defs/rollbackKind"
        },
        "replay_supported": {
          "type": "boolean"
        }
      }
    },
    "executionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dry_run_supported",
        "idempotency_key_required",
        "rate_limit_policy",
        "timeout_seconds"
      ],
      "properties": {
        "dry_run_supported": {
          "type": "boolean"
        },
        "idempotency_key_required": {
          "type": "boolean"
        },
        "rate_limit_policy": {
          "type": [
            "string",
            "null"
          ]
        },
        "timeout_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    },
    "interopContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_product",
        "mode",
        "contract_ref",
        "direction"
      ],
      "properties": {
        "target_product": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "$ref": "#/$defs/interopMode"
        },
        "contract_ref": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": [
            "inbound",
            "outbound",
            "bidirectional"
          ]
        }
      }
    }
  }
}
