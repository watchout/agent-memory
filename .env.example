# ========================================
# wasurezu (agent-memory) Environment Variables
# ========================================
# Copy this file to .env and fill in values for your setup.
# DO NOT commit .env to git.

# ========================================
# Storage Backend Selection
# ========================================
# Choose one of: sqlite (default) | postgres
AGENT_MEMORY_DB_TYPE=sqlite

# ========================================
# SQLite Backend (default — no config required)
# ========================================
# Optional: override default DB path (default: ~/.agent-memory/memory.db)
# AGENT_MEMORY_DB_PATH=/custom/path/memory.db

# ========================================
# PostgreSQL Backend (optional)
# ========================================
# Required if AGENT_MEMORY_DB_TYPE=postgres
# Example: postgresql://user:password@localhost:5432/agent_memory
# AGENT_MEMORY_DATABASE_URL=postgresql://localhost/agent_memory

# ========================================
# Agent Identity (multi-agent support)
# ========================================
# Used to namespace memories per bot. Default: 'default'
# AGENT_MEMORY_AGENT_ID=default

# ========================================
# Project Identity
# ========================================
# Used to namespace memories per project. Default: extracted from cwd
# AGENT_MEMORY_PROJECT=my-project

# ========================================
# Embedding Generation (optional)
# ========================================
# wasurezu uses Voyage AI for embeddings (PostgreSQL + pgvector backend only).
# If not set, embeddings are disabled and search falls back to keyword match.
# Get a free API key at https://voyageai.com
# VOYAGE_API_KEY=

# ========================================
# agent-comms Integration (optional)
# ========================================
# Enables discord_history tool. Only used if AGENT_MEMORY_DB_TYPE=postgres and
# agent-comms is also installed. See docs/SSOT.md for details.
# AGENT_COMMS_DATABASE_URL=postgresql://localhost/agent_comms

# ========================================
# Logging
# ========================================
# Log level: debug | info | warn | error
# LOG_LEVEL=info
