{
  "name": "agent-memory",
  "version": "0.3.0",
  "description": "Persistent memory for AI coding agents. Survives compaction. Works across sessions.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-memory": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx src/test.ts",
    "test:pg": "tsx src/test-pg.ts",
    "migrate": "tsx src/migrate.ts",
    "boot": "tsx src/boot.ts"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "ai-memory",
    "agent",
    "compaction",
    "context-recovery"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "pg": "^8.13.0",
    "sql.js": "^1.14.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
