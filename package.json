{
  "name": "wasurezu",
  "version": "0.3.0",
  "description": "Persistent memory for AI coding agents. Survives compaction. Works across sessions. (wasurezu = Japanese for 'won't forget')",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kusabi": "dist/index.js",
    "wasurezu": "dist/index.js",
    "agent-memory": "dist/index.js",
    "wasurezu-codex-start": "dist/codex-start.js",
    "wasurezu-codex-session-start": "dist/codex-session-start.js",
    "wasurezu-codex-hook-install": "dist/codex-hook-installer.js",
    "wasurezu-claude-start": "dist/claude-start.js",
    "wasurezu-restart": "dist/restart-cli.js"
  },
  "files": [
    "dist",
    "docs/brand",
    "docs/design/SOURCE_ALIGNMENT.md",
    "docs/design/schemas",
    "docs/design/governance",
    "docs/operations/HOST_ADAPTERS.md",
    "docs/operations/WORLD_CLASS_RELEASE_CRITERIA.md",
    "scripts/host-adapters",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/watchout/agent-memory.git"
  },
  "homepage": "https://github.com/watchout/agent-memory",
  "bugs": {
    "url": "https://github.com/watchout/agent-memory/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "prepack": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx src/test.ts",
    "test:pg": "tsx src/test-pg.ts",
    "migrate": "tsx src/migrate.ts",
    "boot": "tsx src/boot.ts",
    "codex:start": "tsx src/codex-start.ts",
    "codex:hook": "tsx src/codex-session-start.ts",
    "codex:hook-install": "tsx src/codex-hook-installer.ts",
    "test:codex-hook": "tsx src/test-codex-session-start.ts && tsx src/test-codex-hook-installer.ts",
    "claude:start": "tsx src/claude-start.ts",
    "company-dev-os:recovery-target-audit": "tsx src/company-dev-os-recovery-target-audit.ts",
    "test:company-dev-os-recovery-target-audit": "tsx src/test-company-dev-os-recovery-target-audit.ts"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "ai-memory",
    "agent",
    "compaction",
    "context-recovery",
    "wasurezu",
    "persistent-memory",
    "llm-memory"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "pg": "^8.13.0",
    "sql.js": "^1.14.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
